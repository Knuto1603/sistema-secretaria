# ============================================================
# Variables de entorno – Sistema Secretaría FII-UNP
#
# Uso local:
#   cp .env.docker.example .env
#   (editar los valores OBLIGATORIO)
#   docker compose up -d --build
#
# EasyPanel:
#   Configurar estas variables en la UI de EasyPanel
#   (Settings → Environment de cada servicio, o a nivel de proyecto)
# ============================================================

# ── Aplicación ────────────────────────────────────────────
APP_NAME="Secretaria FII-UNP"
APP_ENV=production
APP_DEBUG=false
APP_KEY=                          # OBLIGATORIO: genera con: docker compose exec backend php artisan key:generate
APP_URL=http://TU_DOMINIO_O_IP

# ── URL de la API (se inyecta en el build del frontend) ───
# Debe apuntar al dominio/IP donde estará nginx-api
API_URL=http://TU_DOMINIO_O_IP/api

# ── Base de datos ─────────────────────────────────────────
DB_DATABASE=gestion_academica
DB_USERNAME=secretaria
DB_PASSWORD=                      # OBLIGATORIO
DB_ROOT_PASSWORD=                 # OBLIGATORIO

# ── Cache / Sesión / Queue ────────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=database

# ── CORS ──────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=TU_DOMINIO_O_IP

# ── Mail ──────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@unp.edu.pe
MAIL_FROM_NAME="Secretaria FII-UNP"

# ── LLM / Chatbot ─────────────────────────────────────────
LLM_PROVIDER=groq
GROQ_API_KEY=                     # OBLIGATORIO si usas el chatbot
GROQ_MODEL=llama-3.3-70b-versatile

# ── WhatsApp Bot ──────────────────────────────────────────
WHATSAPP_WEBHOOK_SECRET=          # OBLIGATORIO si usas el bot
