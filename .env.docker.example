# ============================================================
# Variables de entorno para Docker
# Copia este archivo como .env.docker y ajusta los valores
# antes del primer despliegue.
#
#   cp .env.docker.example .env.docker
# ============================================================

APP_NAME="Secretaria FII-UNP"
APP_ENV=production
APP_DEBUG=false
APP_KEY=                          # OBLIGATORIO: genera con: docker compose exec backend php artisan key:generate
APP_URL=http://TU_IP_O_DOMINIO

# --- Base de datos ---
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=gestion_academica
DB_USERNAME=secretaria
DB_PASSWORD=                      # OBLIGATORIO: elige una contraseña segura
DB_ROOT_PASSWORD=                 # OBLIGATORIO: elige una contraseña segura

# --- Redis ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# --- Cache / Sesión / Queue ---
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=database

# --- CORS ---
SANCTUM_STATEFUL_DOMAINS=TU_DOMINIO,TU_DOMINIO:80

# --- Mail ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@unp.edu.pe
MAIL_FROM_NAME="Secretaria FII-UNP"

# --- LLM / Chatbot ---
LLM_PROVIDER=groq
GROQ_API_KEY=                     # OBLIGATORIO: pega tu API key de Groq
GROQ_MODEL=llama-3.3-70b-versatile

# --- WhatsApp Bot ---
WHATSAPP_WEBHOOK_SECRET=          # OBLIGATORIO si usas el bot de WhatsApp
